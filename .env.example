# ============================================
#  NevoDevs Workspace — Production Environment
#  Copy to .env and fill in real values:
#    cp .env.example .env
# ============================================

# === Database ===
POSTGRES_USER=nevodevs
POSTGRES_PASSWORD=CHANGE_THIS_strong_db_password
POSTGRES_DB=nevodevs

# === Security ===
# Generate a strong key:  openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_run_openssl_rand_hex_32

# === Environment ===
# "production" enables security startup-checks (refuses to boot with default secrets)
ENVIRONMENT=production

# === URLs ===
# Your public URL — used for CORS. Use https:// once SSL is set up.
FRONTEND_URL=http://your-server-ip
